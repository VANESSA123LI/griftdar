# griftdar environment variables
# Copy this file to .env.local and fill in as needed. NEVER commit real secrets.

# Which data provider to use:
#   mock = hardcoded fixtures, no API key required (default, great for dev)
#   api  = ProxycurlProvider, requires PROXYCURL_API_KEY below
DATA_PROVIDER=mock

# Proxycurl API key — only required when DATA_PROVIDER=api.
# Get one at https://nubela.co/proxycurl
PROXYCURL_API_KEY=

# Optional: override the Proxycurl Person Profile endpoint (defaults to the
# public v2 endpoint). Useful for testing/mocking. Leave blank in normal use.
PROXYCURL_ENDPOINT=
